# Variables de entorno — DVG CRM

# PostgreSQL (AWS RDS)
DATABASE_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Login email + contraseña (hash bcrypt — nunca la contraseña en claro aquí)
CRM_ADMIN_EMAIL=info@dvgsstudio.com
# Generar hash: CRM_ADMIN_PASSWORD='...' node scripts/seed-admin.js
# IMPORTANTE: el hash bcrypt lleva $ — ponlo entre comillas simples
CRM_ADMIN_PASSWORD_HASH='$2b$12$ejemplo...'

# Clave para que la web envíe leads (misma en dvg-studio-landing)
CRM_INGEST_SECRET=

# Email al asignar leads/tareas (opcional — si falta, se omite el envío)
CRM_SMTP_HOST=
CRM_SMTP_PORT=587
CRM_SMTP_USER=
CRM_SMTP_PASS=
CRM_MAIL_FROM=info@dvgsstudio.com

# Round-robin: asignar leads web nuevos al equipo (false para desactivar)
CRM_ROUND_ROBIN=true

# --- Marketing / publicación en X (Twitter API v2, OAuth 1.0a usuario) ---
# Crear app en https://developer.x.com — permisos Read and Write
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Cron Vercel: publicar posts programados (generar en Vercel → Settings → Cron)
CRON_SECRET=

# --- TikTok Content Posting API ---
# App en https://developers.tiktok.com → Content Posting API + Direct Post
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Opcional si no usas el valor por defecto del CRM:
# TIKTOK_REDIRECT_URI=https://crm.dvgsstudio.com/api/marketing/connect/tiktok/callback
# TIKTOK_SCOPES=user.info.basic,video.publish,video.upload
# SELF_ONLY hasta pasar auditoría TikTok; luego PUBLIC_TO_EVERYONE
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
# Fallback manual (OAuth en Marketing → Conexiones es preferible):
# TIKTOK_ACCESS_TOKEN=

# Vídeos en el CRM (TikTok PULL_FROM_URL desde crm.dvgsstudio.com)
# Vercel → proyecto dvg-crm → Storage → Create Blob Store → Connect
BLOB_READ_WRITE_TOKEN=

# Ingest de borradores (Telegram/Bedrock/scripts) — misma clave en AWS secret bedrock-worker/crm-ingest-secret
# POST /api/ingest/marketing-post  Header: x-crm-ingest-secret
# Body batch: { "posts": [{ "platform": "TWITTER", "content": "..." }, ...] }
