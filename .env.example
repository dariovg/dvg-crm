# Variables de entorno — DVG CRM

# PostgreSQL (AWS RDS)
DATABASE_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Login email + contraseña (hash bcrypt — nunca la contraseña en claro aquí)
CRM_ADMIN_EMAIL=info@dvgsstudio.com
# Generar hash: CRM_ADMIN_PASSWORD='...' node scripts/seed-admin.js
# IMPORTANTE: el hash bcrypt lleva $ — ponlo entre comillas simples
CRM_ADMIN_PASSWORD_HASH='$2b$12$ejemplo...'

# Clave para que la web envíe leads (misma en dvg-studio-landing)
CRM_INGEST_SECRET=

# Email al asignar leads/tareas (opcional — si falta, se omite el envío)
CRM_SMTP_HOST=
CRM_SMTP_PORT=587
CRM_SMTP_USER=
CRM_SMTP_PASS=
CRM_MAIL_FROM=info@dvgsstudio.com

# Round-robin: asignar leads web nuevos al equipo (false para desactivar)
CRM_ROUND_ROBIN=true
