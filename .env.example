# Variables de entorno — DVG CRM

# PostgreSQL (AWS RDS)
# Ej: postgresql://dvgcrm:PASSWORD@dvg-crm.xxxx.eu-west-1.rds.amazonaws.com:5432/dvgcrm?sslmode=require
DATABASE_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (login del panel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Emails con acceso (separados por coma)
CRM_ALLOWED_EMAILS=tu@gmail.com
# Tu email = rol ADMIN
CRM_ADMIN_EMAIL=tu@gmail.com

# Clave para que la web envíe leads (misma en dvg-studio-landing)
CRM_INGEST_SECRET=
