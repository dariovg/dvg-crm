generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContactStatus {
  NEW
  CONTACTED
  MEETING_SCHEDULED
  MEETING_DONE
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum UserRole {
  MARKETING
  ADMIN
  MANAGER
  MEMBER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ContactSource {
  WEB_CHAT
  BOOKING
  SURVEY
  MANUAL
}

enum QuoteStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  ACCEPTED
  REJECTED
}

enum QuoteBilling {
  MONTHLY
  ANNUAL
}

enum QuoteLineType {
  PACK
  CUSTOM
}

enum QuoteProjectType {
  WEB
  IA
  CONSULTING
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  image                String?
  passwordHash         String?
  role                 UserRole  @default(MEMBER)
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  totpSecret           String?
  totpEnabled          Boolean   @default(false)
  totpBackupCodes      String[]  @default([])
  tokenVersion         Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  tasks                Task[]    @relation("TaskAssignee")
  events               ContactEvent[]
  loginAttempts        LoginAttempt[]
  assignedContacts     Contact[] @relation("ContactAssignee")
  createdContacts      Contact[] @relation("ContactCreator")
  notifications        Notification[]
  createdQuotes        Quote[]   @relation("QuoteCreator")
  approvedQuotes       Quote[]   @relation("QuoteApprover")
  socialPostsCreated   SocialPost[] @relation("SocialPostCreator")
  campaignsCreated     Campaign[]   @relation("CampaignCreator")
  postsApproved        PostApproval[] @relation("PostApproval")
  marketingTemplates   MarketingTemplate[] @relation("MarketingTemplateCreator")
  auditLogs            AuditLog[]
  sessions             UserSession[]
}

model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String?
  entityId   String?
  summary    String
  payload    Json?
  ipHash     String?

  @@index([createdAt])
  @@index([userId])
  @@index([action])
}

model UserSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ipHash     String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
  @@index([revokedAt])
  @@index([createdAt])
}

model AppSetting {
  key   String @id
  value String
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  read      Boolean  @default(false)
  type      String
  title     String
  body      String?
  link      String?

  @@index([userId, read])
  @@index([createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  email     String
  ipHash    String
  success   Boolean  @default(false)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, ipHash, createdAt])
  @@index([createdAt])
}

model Contact {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  name      String
  email     String
  company   String?
  phone     String?
  status    ContactStatus @default(NEW)
  source    ContactSource @default(WEB_CHAT)
  interest   String?
  notes      String?       @db.Text
  assigneeId String?
  assignee   User?         @relation("ContactAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?         @relation("ContactCreator", fields: [createdById], references: [id], onDelete: SetNull)
  dealValue   Int?
  tags        String[]      @default([])
  lostReason  String?
  leadScore   Int?
  events     ContactEvent[]
  meetings  Meeting[]
  tasks     Task[]
  surveys   SurveyResponse[]
  quotes    Quote[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([assigneeId])
}

model ContactEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String
  summary   String
  payload   Json?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([contactId])
}

model Meeting {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  date            String
  time            String
  meetUrl         String?
  calendarEventId String?
  notes           String?  @db.Text

  @@index([contactId])
}

model SurveyResponse {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  email     String?
  name      String?
  answers   Json
  score     Int?

  @@index([email])
}

model Task {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  contactId  String
  contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title      String
  dueAt      DateTime?
  done       Boolean   @default(false)
  assigneeId String?
  assignee   User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  priority   TaskPriority @default(MEDIUM)
  recurDays  Int?

  @@index([contactId])
  @@index([dueAt])
  @@index([done])
}

model Quote {
  id              String       @id @default(cuid())
  number          String       @unique
  contactId       String
  contact         Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdById     String?
  createdBy       User?        @relation("QuoteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  status          QuoteStatus  @default(DRAFT)
  billing         QuoteBilling @default(MONTHLY)
  packId          String?
  discountPercent Int?
  notes           String?      @db.Text
  validUntil      DateTime?
  approvalNote    String?
  approvedById    String?
  approvedBy      User?        @relation("QuoteApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  sentAt          DateTime?
  projectType     QuoteProjectType @default(IA)
  shareToken      String?          @unique
  pdfFirstOpenedAt DateTime?
  pdfLastOpenedAt  DateTime?
  pdfOpenCount     Int              @default(0)
  clientSignature  String?          @db.Text
  signedAt         DateTime?
  signedByName     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  lines           QuoteLine[]

  @@index([contactId])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
  @@index([shareToken])
}

model QuoteLine {
  id              String        @id @default(cuid())
  quoteId         String
  quote           Quote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  type            QuoteLineType
  description     String        @db.Text
  quantity        Int           @default(1)
  unitPrice       Int
  discountPercent Int?
  sortOrder       Int           @default(0)
  packId          String?

  @@index([quoteId])
}

enum SocialPostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
  REJECTED
}

enum SocialPlatform {
  TWITTER
  INSTAGRAM
  TIKTOK
  LINKEDIN
  FACEBOOK
}

model SocialPost {
  id              String              @id @default(cuid())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  platform        SocialPlatform
  content         String              @db.Text
  status          SocialPostStatus    @default(DRAFT)
  campaignId      String?
  campaign        Campaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  errorMessage    String?
  createdById     String?
  createdBy       User?               @relation("SocialPostCreator", fields: [createdById], references: [id], onDelete: SetNull)
  externalId      String?
  publishAttempts Int                 @default(0)
  lastPublishAttemptAt DateTime?
  likes           Int                 @default(0)
  comments        Int                 @default(0)
  shares          Int                 @default(0)
  impressions     Int                 @default(0)
  approvals       PostApproval[]
  mediaUrls       String[]            @default([])

  @@index([platform])
  @@index([status])
  @@index([campaignId])
  @@index([createdAt])
  @@index([publishedAt])
}

model Campaign {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  name            String
  description     String?     @db.Text
  startDate       DateTime
  endDate         DateTime?
  status          String      @default("ACTIVE")
  posts           SocialPost[]
  createdById     String?
  createdBy       User?       @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
}

model PostApproval {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  postId          String
  post            SocialPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  approvedById    String?
  approvedBy      User?       @relation("PostApproval", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  notes           String?     @db.Text
  status          String      @default("PENDING")

  @@index([postId])
  @@index([approvedById])
  @@index([createdAt])
}

model MarketingTemplate {
  id          String   @id @default(cuid())
  name        String
  content     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("MarketingTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

// Tokens OAuth por red (TikTok, LinkedIn, Meta) — una cuenta por plataforma.
model SocialConnection {
  id           String         @id @default(cuid())
  platform     SocialPlatform @unique
  accessToken  String         @db.Text
  refreshToken String?        @db.Text
  openId       String?
  scope        String?
  expiresAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}
