{
  "name": "dvg-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "node scripts/seed-admin.js && node scripts/seed-finance-categories.js",
    "postinstall": "prisma generate",
    "test:unit": "node --experimental-test-module-mocks --test tests/**/*.test.mjs",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@sentry/nextjs": "^9.15.0",
    "@vercel/blob": "^2.4.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.4.0",
    "next": "^15.2.5",
    "next-auth": "^4.24.14",
    "nodemailer": "^6.9.16",
    "otplib": "^12.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.51.0",
    "@types/node": "20.17.6",
    "@types/react": "19.2.17",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "postcss": "^8",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "5.8.2"
  }
}
